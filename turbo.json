{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "POSTGRES_URL"
      ],
      "inputs": [
        "src/**",
        "public/**",
        "package.json",
        "tsconfig*.json",
        "next.config.*",
        "tailwind.config.*",
        ".env*",
        "!src/**/*.test.*",
        "!src/**/*.spec.*"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate:types": {
      "cache": false,
      "persistent": true
    },
    "generate:importmap": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"]
    },
    "test:int": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "env": [
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "STRIPE_SECRET_KEY",
        "E2E_USE_PROD"
      ],
      "inputs": [
        "tests/e2e/**",
        "playwright.config.ts",
        "package.json",
        ".env*"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "test:e2e:ci": {
      "dependsOn": ["build"],
      "env": [
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "STRIPE_SECRET_KEY",
        "E2E_USE_PROD"
      ],
      "inputs": [
        "tests/e2e/**",
        "playwright.config.ts",
        "package.json",
        ".env*"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "payload": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "ci": {
      "dependsOn": ["^ci"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"]
    }
  }
}
