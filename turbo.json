{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "BLOB_READ_WRITE_TOKEN",
        "POSTGRES_URL"
      ],
      "inputs": [
        "src/**",
        "public/**",
        "package.json",
        "tsconfig*.json",
        "next.config.*",
        "tailwind.config.*",
        ".env*",
        "!src/**/*.test.*",
        "!src/**/*.spec.*"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NEXT_PHASE",
        "LOGS_STRIPE_PROXY",
        "DEFAULT_FROM_ADDRESS",
        "NEXT_PUBLIC_BETTER_AUTH_URL",
        "NEXT_PUBLIC_SERVER_URL",
        "SERVER_URL",
        "RESEND_FROM",
        "DEFAULT_FROM_NAME",
        "RESEND_API_KEY",
        "BETTER_AUTH_SECRET",
        "ENABLE_TEST_MAGIC_LINKS",
        "ENABLE_TEST_WEBHOOKS",
        "TZ"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate:types": {
      "cache": false,
      "persistent": true
    },
    "generate:importmap": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"]
    },
    "test:int": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"],
      "cache": false
    },
    "test:unit": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"],
      "cache": false
    },
    "test:int:shard": {
      "dependsOn": ["^build"],
      "env": [
        "VITEST_SHARD",
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "FORCE_EXISTING_DB",
        "CI",
        "NODE_OPTIONS"
      ],
      "cache": false
    },
    "test:e2e:shard": {
      "dependsOn": ["build"],
      "env": [
        "PLAYWRIGHT_SHARD",
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "PAYLOAD_PUBLIC_STRIPE_IS_TEST_KEY",
        "RESEND_API_KEY",
        "ENABLE_TEST_MAGIC_LINKS",
        "ENABLE_TEST_WEBHOOKS",
        "E2E_USE_PROD",
        "PW_E2E_SKIP_WEBSERVER_MIGRATE",
        "PW_E2E_MAX_FAILURES",
        "PW_E2E_SKIP_DEFAULT_TENANT_DATA",
        "PW_TEST_HTML_REPORT_OPEN",
        "CI",
        "NODE_OPTIONS"
      ],
      "inputs": [
        "tests/e2e/**",
        "playwright.config.ts",
        "package.json",
        ".env*"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "db:prepare": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET", "CI", "NODE_ENV"],
      "cache": false
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "env": [
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "STRIPE_SECRET_KEY",
        "E2E_USE_PROD"
      ],
      "inputs": [
        "tests/e2e/**",
        "playwright.config.ts",
        "package.json",
        ".env*"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "test:e2e:ci": {
      "dependsOn": ["build"],
      "env": [
        "DATABASE_URI",
        "PAYLOAD_SECRET",
        "NEXT_PUBLIC_SERVER_URL",
        "STRIPE_SECRET_KEY",
        "E2E_USE_PROD"
      ],
      "inputs": [
        "tests/e2e/**",
        "playwright.config.ts",
        "package.json",
        ".env*"
      ],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    },
    "payload": {
      "cache": false
    },
    "db:reset": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "ci": {
      "dependsOn": ["^ci"],
      "env": ["DATABASE_URI", "PAYLOAD_SECRET"]
    }
  }
}
