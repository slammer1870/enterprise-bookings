# Database connection string
DATABASE_URL=mongodb://127.0.0.1/your-database-name
# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name
# Used to encrypt JWT tokens
PAYLOAD_SECRET=46cc6c02a50106e30c998635
# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
# Optional (recommended in production): internal token used by middleware to call tenant resolver endpoints.
# If set, `/api/tenant-by-host` and `/api/tenant-by-slug` require `x-internal-tenant-resolve` to match.
#INTERNAL_TENANT_RESOLVE_TOKEN=change-me
# Optional: comma-separated extra trusted origins for Better Auth (OAuth/callbacks).
# You can provide either hostnames (defaults to https://) or fully-qualified origins.
# Examples:
# - hostnames: studio.example.com,book.yoga.co
# - origins: http://new.brugrappling.ie,https://new.brugrappling.ie
#BETTER_AUTH_TRUSTED_ORIGINS_EXTRA=studio.example.com,book.yoga.co
# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE
# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE
RESEND_API_KEY=test-key
DEFAULT_FROM_ADDRESS=noreply@test.com
DEFAULT_FROM_NAME=Test App
# Stripe Connect (Phase 2 – OAuth, webhooks, platform payments)
# Platform secret key; required for Connect OAuth token exchange and API calls
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Optional: Stripe API version (Stripe-Version) for server requests and webhook enforcement. Default: 2026-02-25.clover. Must match your webhook endpoint pin in Dashboard.
#STRIPE_API_VERSION=2026-02-25.clover
# Connect application client ID (Stripe Dashboard → Connect → Settings)
STRIPE_CONNECT_CLIENT_ID=ca_xxx
# Webhook signing secret for Stripe Connect events (account.*, customer.subscription.*)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx
# Webhook signing secret for platform events (payment_intent.succeeded for subdomain/destination charges)
STRIPE_WEBHOOK_SECRET=whsec_yyy
# Webhook api_version is enforced by default (must match PLATFORM_STRIPE_API_VERSION in src/lib/stripe/platform.ts). Set to false only for local/debug if the Stripe endpoint is not pinned yet.
#STRIPE_ENFORCE_WEBHOOK_API_VERSION=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Optional: Google OAuth for "Login with Google" on complete-booking (and other auth flows)
# Get credentials from Google Cloud Console → APIs & Services → Credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google (dev) and https://your-domain.com/api/auth/callback/google (prod)
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=

# Optional: Cloudflare R2 storage for Media uploads (Phase 5.5).
# Option A – Direct S3 API: set R2_ACCOUNT_ID + credentials + R2_BUCKET_NAME (get from Cloudflare → R2 → Manage R2 API Tokens).
#R2_ACCOUNT_ID=your_cloudflare_account_id
#R2_ACCESS_KEY_ID=your_r2_access_key_id
#R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
#R2_BUCKET_NAME=your_bucket_name
# Option B – Via Worker (use when direct TLS to R2 fails, e.g. EPROTO): set R2_WORKER_URL + R2_WORKER_SECRET + R2_BUCKET_NAME. See apps/atnd-me/worker-r2-proxy/README.md.
#R2_WORKER_URL=https://atnd-me-r2-proxy.your-subdomain.workers.dev
#R2_WORKER_SECRET=your_shared_secret
#R2_BUCKET_NAME=your_bucket_name
# Optional: when set to "true", tenant custom domain saves require the domain to have DNS records (A, AAAA, or CNAME). Leave unset in dev so tenants can be saved before DNS is configured.
#VALIDATE_TENANT_CUSTOM_DOMAIN_DNS=true
# Optional: custom domain for public media URLs (e.g. https://media.example.com)
#R2_PUBLIC_URL=https://media.example.com
# On direct S3 only: set to true on Hetzner/Coolify to use SDK default TLS (can fix EPROTO)
#R2_USE_DEFAULT_CLIENT=true